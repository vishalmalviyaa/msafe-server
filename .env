DJANGO_SECRET_KEY=some-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.31.109
POSTGRES_DB=vishkey_db
POSTGRES_USER=vishkey_user
POSTGRES_PASSWORD=vishkey_pass
DB_HOST=db
DB_PORT=5432

DPC_API_KEY=super-secret-dpc-key

# Put your REAL FCM key here
FCM_SERVER_KEY=YOUR_REAL_FCM_SERVER_KEY

AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_STORAGE_BUCKET_NAME=your_bucket
AWS_S3_REGION_NAME=ap-south-1

# Redis / Celery (these match your scalability_core config)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
